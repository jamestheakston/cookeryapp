{
  "version": "1.0.0",
  "project": "cookeryapp",
  "maintainer": "@jamestheakston",
  "pr": {
    "header": "✨ Powered by AutoPR - a custom software made by @jamestheakston for this project",
    "autoMerge": false,
    "requireReviews": true,
    "baseBranch": "main",
    "branchPrefix": "feature/",
    "labels": {
      "bug": "bug",
      "feature": "enhancement",
      "documentation": "documentation",
      "styling": "ui"
    }
  },
  "commit": {
    "conventional": false,
    "maxSubjectLength": 72,
    "maxBodyLength": 2000
  },
  "review": {
    "requiredReviewers": 1,
    "allowSelfReview": false,
    "requireChecksPass": true
  },
  "files": {
    "ignore": [
      "*.DS_Store",
      "*.log",
      "node_modules/",
      ".git/"
    ],
    "trackExtensions": [
      ".html",
      ".css",
      ".js",
      ".md",
      ".json",
      ".png",
      ".jpg",
      ".svg"
    ]
  },
  "integrations": {
    "github": {
      "enabled": true,
      "apiVersion": "2022-11-28"
    },
    "ai": {
      "enabled": true,
      "promptFile": "prompt.md"
    }
  }
}
